[Unit]
Description=Gunicorn instance to serve InteliPark Backend
After=network.target

[Service]
User=intelipark
Group=intelipark
WorkingDirectory=/home/intelipark/InteliPark/Backend
Environment="PATH=/home/intelipark/InteliPark/Backend/venv/bin"
EnvironmentFile=/home/intelipark/InteliPark/Backend/.env
ExecStart=/home/intelipark/InteliPark/Backend/venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker -b 127.0.0.1:8000 app.main:app

[Install]
WantedBy=multi-user.target
